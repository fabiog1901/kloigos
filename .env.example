DB_URL = "postgres://kloigos:kloigos@localhost:5432/kloigos?sslmode=require"

# ---------- OIDC / JWT auth ----------
# Set to true to require authentication for /api/admin/* and /api/compute_units/*
OIDC_ENABLED = false

# Provider details (Keycloak / Okta / Entra / Google / Auth0)
OIDC_ISSUER_URL = ""
OIDC_CLIENT_ID = ""
OIDC_CLIENT_SECRET = ""
OIDC_SCOPES = "openid profile email"

# Optional; commonly needed with Auth0 APIs
OIDC_AUDIENCE = ""

# Optional JSON object for provider-specific params
# Example: {"prompt":"login","access_type":"offline"}
OIDC_EXTRA_AUTH_PARAMS = "{}"

# Optional override for callback URL; if empty, app derives from request.url_for("oidc_callback")
OIDC_REDIRECT_URI = ""

# Cookie/session controls
OIDC_SESSION_COOKIE_NAME = "kloigos_session"
OIDC_COOKIE_SECURE = false
OIDC_COOKIE_SAMESITE = "lax"
OIDC_COOKIE_DOMAIN = ""
OIDC_VERIFY_AUDIENCE = false
OIDC_UI_USERNAME_CLAIM = "preferred_username"

# Authorization controls
# Base64-encoded 32-byte master key used to encrypt API key secrets at rest.
# Example generation: openssl rand -base64 32
API_KEY_MASTER_KEY = ""
# CSV list of groups that map to Kloigos roles.
# - readonly users can call GET endpoints under /api/compute_units/*
# - user users can call all /api/compute_units/* endpoints
# - admin users can call all /api/admin/* endpoints and all compute_units endpoints
API_KEY_SIGNATURE_TTL_SECONDS = 300
OIDC_AUTHZ_READONLY_GROUPS = ""
OIDC_AUTHZ_USER_GROUPS = ""
OIDC_AUTHZ_ADMIN_GROUPS = ""
# Claim name in the token that contains user groups.
OIDC_AUTHZ_GROUPS_CLAIM = "groups"
